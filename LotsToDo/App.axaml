<Application xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:LotsToDo"
        x:Class="LotsToDo.App"
        RequestedThemeVariant="Default">
        <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/ThemeAssets/Colors.axaml" />
                <MergeResourceInclude Source="/ThemeAssets/Textbox.axaml" />
                <MergeResourceInclude Source="/ThemeAssets/BaseButton.axaml" />
                <MergeResourceInclude Source="/ThemeAssets/DeleteButton.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>