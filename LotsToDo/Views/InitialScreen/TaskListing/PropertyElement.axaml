<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LotsToDo.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LotsToDo.Views.InitialScreen.TaskListing.PropertyElement"
        x:DataType="vm:ToDoListViewModel">
    <Border Margin="10" CornerRadius="10" Background="rgb(25, 25, 50)" Height="80" Width="400">
        <StackPanel>
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Margin="10 10 10 10" Foreground="White" FontSize="20" Text="thing">
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>