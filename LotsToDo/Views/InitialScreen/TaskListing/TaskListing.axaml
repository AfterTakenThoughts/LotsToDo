<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LotsToDo.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LotsToDo.Views.InitialScreen.TaskListing.TaskListing"
        x:DataType="vm:MainViewModel"
        xmlns:controls="clr-namespace:LotsToDo.Views.InitialScreen.TaskListing">
    <ItemsControl ItemsSource="{Binding ToDoItemList}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Margin="10" CornerRadius="10" Background="{DynamicResource ForegroundColor}" Height="80" Width="400">
                    <StackPanel>
                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                            Margin="10 10 10 10" Foreground="White" FontSize="20" Text="{Binding Content}">
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <Border Margin="10 0 0 0" CornerRadius="10" BorderThickness="2" BorderBrush="rgba(255, 0, 0)" Height="24">
                                <TextBlock Margin="10 0" Foreground="White" Text="Due ">
                                    <Run Text="{Binding DueDate}" />
                                </TextBlock>
                            </Border>
                            <Border Margin="10 0 0 0" CornerRadius="10" BorderThickness="2" BorderBrush="Yellow" Height="24">
                                <TextBlock Margin="10 0" Foreground="White" Text="Started ">
                                    <Run Text="{Binding StartDate}" />
                                </TextBlock>
                            </Border>
                            <Border Margin="10 0 0 0" CornerRadius="10" BorderThickness="2" BorderBrush="Lime" Height="24">
                                <TextBlock Margin="10 0" Foreground="White" Text="Created ">
                                    <Run Text="{Binding CreateDate}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>