<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LotsToDo.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LotsToDo.Views.InitialScreen.TaskListing.TaskListing"
        x:DataType="vm:ToDoListViewModel"
        xmlns:controls="clr-namespace:LotsToDo.Views.InitialScreen.TaskListing">
    <ItemsControl ItemsSource="{Binding ToDoItemList}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal">
                    <Border Margin="10" CornerRadius="10" Background="{DynamicResource ForegroundColor}" Width="400">
                        <StackPanel>
                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                Margin="10 10 10 10" Foreground="White" FontSize="20" Text="{Binding Content}">
                            </TextBlock>
                            <controls:TagListing Margin="0, -5, 0, 5"/>
                        </StackPanel>
                    </Border>
                    <Button Theme="{DynamicResource DeleteButton}" Height="30" Width="90"
                        Command="{Binding $parent[ItemsControl].((vm:ToDoListViewModel)DataContext).RemoveItemCommand}" CommandParameter="{Binding .}">
                        Delete Task
                    </Button>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>