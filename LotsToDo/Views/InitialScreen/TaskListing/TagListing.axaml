<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LotsToDo.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LotsToDo.Views.InitialScreen.TaskListing.TagListing"
        x:DataType="vm:TaskItemViewModel">
    <ItemsControl ItemsSource="{Binding Tags}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <WrapPanel Orientation="Horizontal">
                    <Border Margin="5 2 5 2" CornerRadius="10" BorderThickness="2" BorderBrush="rgba(255, 255, 255)" Height="24">
                        <TextBlock Margin="10 0" Foreground="White" Text="{Binding}"/>
                    </Border>
                </WrapPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>