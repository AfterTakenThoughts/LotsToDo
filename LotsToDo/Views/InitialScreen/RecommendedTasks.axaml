<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LotsToDo.ViewModels"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
    x:Class="LotsToDo.Views.InitialScreen.RecommendedTasks"
    x:DataType="vm:ToDoListViewModel"
    Background="{DynamicResource BackgroundColor}"
    xmlns:control1="clr-namespace:LotsToDo.Views.InitialScreen.TaskListing"
    xmlns:control2="clr-namespace:LotsToDo.Views.InitialScreen.AddTaskElement">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:ToDoListViewModel />
    </Design.DataContext>

    <Grid>
        <StackPanel>
            <TextBlock Margin="20" FontSize="20" Foreground="White"
                FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top">
                LotsToDo
            </TextBlock>
            <TextBlock
                Margin="10" FontSize="20" Foreground="White"
                FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Top">
                Your To Do List
            </TextBlock>
            <control1:TaskListing HorizontalAlignment="Center"/>
        </StackPanel>
        <!-- <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="White" Click="Button_Click">Add a Task</Button> -->
        <control2:AddTaskElement Margin="0 50" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>