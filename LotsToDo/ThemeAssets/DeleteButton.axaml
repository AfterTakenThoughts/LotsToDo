<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme x:Key="DeleteButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource DeleteColor}"/>
        <Setter Property="Padding" Value="7"/>
        <Setter Property="CornerRadius" Value="10"/>
        
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource DeleteHoverColor}"/>
        </Style>

        <Style Selector="^:focus">
            <Setter Property="Background" Value="{DynamicResource DeleteFocusColor}"/>
        </Style>
    </ControlTheme>
</ResourceDictionary>